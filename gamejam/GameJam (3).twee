:: StoryStylesheet [stylesheet]
/* Rend le lien invisible et couvre tout l'écran */
.ecran-cliquable a {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    display: block;
    background: transparent;
    color: transparent !important; /* Cache le texte du lien */
    border: none !important;
    text-decoration: none !important;
    z-index: 9999;
}

/* Supprime les pointillés moches quand on clique */
.ecran-cliquable a:focus {
    outline: none;
}

body {
  background-image: url("image/exterieur.jpg");
  background-size: cover;
  background-attachment: fixed;
  background-position: center;
  color: #000000;
}


#ui-dialog-body {
  background-color: #222222; /* Remplace par la couleur de ton choix (ici un gris très foncé) */
  color: #ffffff;            /* Force le texte de l'historique à s'afficher en blanc */
}

.portrait-personnage {
  width: 150px;
  height: auto;
  border-radius: 10px; /* Arrondit légèrement les coins */
  display: block;      /* Centre l'image si besoin */
  margin: 0 auto;     /* Centre l'image horizontalement */
}