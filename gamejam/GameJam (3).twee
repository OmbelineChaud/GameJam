        	<<set $log.push("Je vois, quelque chose à ajouter? Plus de détails peut-être?")>>
            <<linkreplace "[Continuer...] ">>
            <<set $persoActuel to "Hero">><<majPortrait>>
        		<<append "#story-output">><br><br><strong>Hero</strong><</append>>
        		<<append "#story-output">><br><br>Non, je ne crois pas.<</append>>
        		<<set $log.push("Non, je ne crois pas.")>>
            	<<linkreplace "[Continuer...] ">>
                <<set $persoActuel to "policier">><<majPortrait>>
        			<<append "#story-output">><br><br><strong>Policier 1 </strong><</append>>
        			<<append "#story-output">><br><br>Je vais faire le tour du reste de votre équipe alors. Si jamais quelque chose vous revient, n’hésitez pas à me contacter. <</append>>
        			<<set $log.push("Je vais faire le tour du reste de votre équipe alors. Si jamais quelque chose vous revient, n’hésitez pas à me contacter. ")>>
            		<<linkreplace "[Continuer...] ">>
        				<<append "#story-output">><br><br><strong>Narration</strong><</append>>
        				<<append "#story-output">><br><br>Agent POLICIER1 vous donne son numéro professionnel.<</append>>
        				<<set $log.push("Agent POLICIER1 vous donne son numéro professionnel.")>>
            			<<linkreplace "[Continuer...] ">>
        					<<append "#story-output">><br><br><strong>Narration</strong><</append>>
        					<<append "#story-output">><br><br>Après avoir fait votre déclaration à la police, vous rentrez à la caserne avec votre équipe. Le Sergent vous ayant déjà fait une leçon de morale, le reste de l'équipe vous laisse tranquille.<</append>>
        					<<set $log.push("Après avoir fait votre déclaration à la police, vous rentrez à la caserne avec votre équipe. Le Sergent vous ayant déjà fait une leçon de morale, le reste de l'équipe vous laisse tranquille.")>>
            				<<linkreplace "[Continuer...] ">>
        						<<append "#story-output">><br><br><strong>Narration</strong><</append>>
        						<<append "#story-output">><br><br>Vous êtes épuisé.<</append>>
        						<<set $log.push("Vous êtes épuisé.")>>
                                	<<linkreplace "[Continuer...] ">>
        								<<append "#story-output">><br><br><strong>[[Caserne]]</strong><</append>>
        						<</linkreplace>>
        					<</linkreplace>>
        				<</linkreplace>>
        			<</linkreplace>>
